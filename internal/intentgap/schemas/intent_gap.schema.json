{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://semantica.sh/schemas/intent_gap.schema.json",
  "title": "Intent-Gap Finding",
  "description": "A single intent-gap finding from the PR review-intelligence pipeline. The schema covers actual findings only; insufficient-data states (thin_prompts, low_capture_coverage, etc.) are statuses on the result row, never findings. See plans/intent-gap-findings-v1.md.",
  "type": "object",
  "required": ["schema_version", "finding_id", "kind", "title", "confidence"],
  "properties": {
    "schema_version": { "const": "1" },
    "finding_id": {
      "type": "string",
      "pattern": "^f_[0-9a-f]{16}$",
      "description": "Stable id derived from (repository_id, pr_number, kind, kind-specific anchors). Reproducible across re-runs that don't change the cited anchors; feedback rows reference it."
    },
    "kind": {
      "type": "string",
      "enum": ["under_impl", "unrequested", "deferred"]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "high is reserved for cases with multiple corroborating signals (prompt mentions a specific symbol, AI-authored region contains that symbol, ai_exact evidence class)."
    },
    "data_gaps": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Honest notes about what could not be verified - e.g. 'redaction stripped the cap value' or 'no playbook for commit Y'."
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/underImplFinding" },
    { "$ref": "#/$defs/unrequestedFinding" },
    { "$ref": "#/$defs/deferredFinding" }
  ],
  "$defs": {
    "lineRange": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "minItems": 2,
      "maxItems": 2,
      "description": "Inclusive [start, end] 1-indexed line range."
    },
    "evidenceClass": {
      "type": "string",
      "enum": ["ai_exact", "ai_formatted", "ai_modified", "ai_provider_only"]
    },
    "promptCitation": {
      "type": "object",
      "required": ["turn_id", "prompt_excerpt", "prompt_excerpt_hash"],
      "properties": {
        "turn_id": { "type": "string" },
        "prompt_excerpt": { "type": "string" },
        "prompt_excerpt_hash": {
          "type": "string",
          "description": "Hash of the prompt excerpt; load-bearing for finding_id stability."
        }
      }
    },
    "fileRegion": {
      "type": "object",
      "required": ["file", "lines"],
      "properties": {
        "file": { "type": "string" },
        "lines": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/lineRange" }
        }
      }
    },
    "underImplFinding": {
      "type": "object",
      "required": ["kind", "expected_intent", "observed_diff_evidence", "missing_or_partial_area"],
      "properties": {
        "kind": { "const": "under_impl" },
        "expected_intent": {
          "type": "object",
          "required": ["summary", "turn_id", "prompt_excerpt", "prompt_excerpt_hash"],
          "properties": {
            "summary": { "type": "string" },
            "turn_id": { "type": "string" },
            "prompt_excerpt": { "type": "string" },
            "prompt_excerpt_hash": { "type": "string" }
          }
        },
        "observed_diff_evidence": {
          "type": "object",
          "required": ["summary", "ai_authored_regions_checked"],
          "properties": {
            "summary": { "type": "string" },
            "ai_authored_regions_checked": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/fileRegion" }
            }
          }
        },
        "missing_or_partial_area": {
          "type": "object",
          "required": ["note"],
          "properties": {
            "closest_match": {
              "type": "object",
              "required": ["file", "lines"],
              "properties": {
                "file": { "type": "string" },
                "lines": { "$ref": "#/$defs/lineRange" }
              }
            },
            "note": { "type": "string" }
          }
        },
        "trajectory_note": {
          "type": "string",
          "description": "Empty for under_impl; the field exists so deferred reclassification can write through the same shape."
        }
      }
    },
    "unrequestedFinding": {
      "type": "object",
      "required": ["kind", "delivered", "captured_intent_search"],
      "properties": {
        "kind": { "const": "unrequested" },
        "delivered": {
          "type": "object",
          "required": ["file", "line_range", "evidence_class", "summary"],
          "properties": {
            "file": { "type": "string" },
            "line_range": { "$ref": "#/$defs/lineRange" },
            "evidence_class": { "$ref": "#/$defs/evidenceClass" },
            "summary": { "type": "string" }
          }
        },
        "captured_intent_search": {
          "type": "object",
          "required": ["prompts_considered", "result", "qualifier"],
          "properties": {
            "prompts_considered": { "type": "integer", "minimum": 0 },
            "result": {
              "type": "string",
              "description": "Deliberate phrasing: 'No supporting captured intent found' (not 'no prompt mentions this') so the wording matches imperfect-capture reality."
            },
            "qualifier": {
              "type": "string",
              "description": "Plain-language hedge that absence-of-evidence is not proof-of-absence."
            }
          }
        }
      }
    },
    "deferredFinding": {
      "type": "object",
      "required": ["kind", "originally_requested_in", "trajectory_note", "current_state"],
      "properties": {
        "kind": { "const": "deferred" },
        "originally_requested_in": { "$ref": "#/$defs/promptCitation" },
        "trajectory_note": {
          "type": "string",
          "minLength": 1,
          "description": "Cites the intermediate add-then-remove sequence plus the corrective prompt; this is what tells deferred apart from a silent drop."
        },
        "current_state": {
          "type": "object",
          "required": ["file", "line_range", "summary"],
          "properties": {
            "file": { "type": "string" },
            "line_range": { "$ref": "#/$defs/lineRange" },
            "summary": { "type": "string" }
          }
        }
      }
    }
  }
}
